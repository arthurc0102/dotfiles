## Special order plugins

# fzf-tab configs

# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
# NOTE: don't use escape sequences (like '%F{red}%d%f') here, fzf-tab will ignore them
zstyle ':completion:*:descriptions' format '[%d]'
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
zstyle ':completion:*' menu no
# preview directory's content with eza when completing cd
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath'
# custom fzf flags
zstyle ':fzf-tab:*' fzf-flags --height=~50% --layout=reverse --border --ansi
# switch group using `<` and `>`
zstyle ':fzf-tab:*' switch-group '<' '>'

# fzf-tab needs to be loaded after compinit, but before plugins which will wrap widgets, such as zsh-autosuggestions or fast-syntax-highlighting
zinit wait lucid for \
    depth'1' \
    atinit'
        ZINIT[COMPINIT_OPTS]="-d $ZSH_COMPDUMP"
        zicompinit
        zicdreplay
    ' \
        Aloxaf/fzf-tab

# Vite+ configs

# DO NOT DELETE the marker line below.
#
# The vite-plus installer (curl -fsSL https://vite.plus | bash) runs a literal
# `grep -F` over this file for that path string. On a match it treats the shell
# as "already configured" and skips appending its own block; delete it and the
# next install/update bluntly re-appends `. "$HOME/.local/share/vite-plus/env"`
# into this rc. Keep the string byte-for-byte: the $HOME form, no expansion.
#
# vite-plus installer marker: $HOME/.local/share/vite-plus/env
#
# vp's completion is registered via the compdef calls inside $VP_HOME/env.
# In this config, compinit runs lazily (inside fzf-tab's turbo block), so
# sourcing env here would call compdef before compinit exists and silently
# no-op. Defer it with wait'1' so it loads after fzf-tab (and thus after compinit).

zinit wait'1' lucid for \
    id-as'_local---vite-plus-env' \
    depth'1' \
    nocompile \
    atload'
        [[ -f "$VP_HOME/env" ]] && . "$VP_HOME/env"
    ' \
        zdharma-continuum/null

# Fast syntax should be second to last plugin to work normally.
zinit wait lucid for \
    depth'1' \
        zdharma-continuum/fast-syntax-highlighting

# This should be the last plugin to load to avoid auto select suggestions when tab is pressed.
zinit wait lucid for \
    depth'1' \
    atload'!_zsh_autosuggest_start' \
        zsh-users/zsh-autosuggestions


## Load theme

zinit ice \
    as'program' \
    from'gh-r' \
    atclone'
        mkdir -p $ZPFX/bin
        ln -svf $PWD/starship $ZPFX/bin
        ./starship init zsh > init.zsh
        ./starship completions zsh > _starship
    ' \
    atpull'%atclone' \
    atload'
        # Disable virtual env prompt starship will handle it.
        export VIRTUAL_ENV_DISABLE_PROMPT=true

        # Set completion colors to be the same as `ls`, after theme has been loaded.
        [[ -z "$LS_COLORS" ]] || zstyle ":completion:*" list-colors "${(s.:.)LS_COLORS}"
    ' \
    src'init.zsh' \
    pick'$ZPFX/bin/starship'

zinit light starship/starship

