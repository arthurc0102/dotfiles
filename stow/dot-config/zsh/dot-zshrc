# region: zsh

## Cache dir

ZSH_CACHE_DIR="${XDG_CACHE_HOME:-${HOME}/.cache}/zsh"

[[ ! -d $ZSH_CACHE_DIR ]] && mkdir -p "$ZSH_CACHE_DIR"


## Compdump file

ZSH_COMPDUMP="$ZSH_CACHE_DIR/zcompdump-$ZSH_VERSION"


## History

HISTFILE="$XDG_STATE_HOME/zsh/history"

[[ ! -d $(dirname $HISTFILE) ]] && mkdir -p "$(dirname $HISTFILE)"

HISTSIZE=50000
SAVEHIST=50000

setopt inc_append_history


## Options

setopt interactivecomments  # Recognize comments

# endregion


# region: zinit

## Install

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

[[ ! -d $ZINIT_HOME ]] && mkdir -p "$(dirname $ZINIT_HOME)"
[[ ! -d $ZINIT_HOME/.git ]] && git clone --depth 1 https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"

source "${ZINIT_HOME}/zinit.zsh"


## Load oh-my-zsh stuff

zinit for \
    OMZL::history.zsh \
    OMZL::theme-and-appearance.zsh \
    OMZL::completion.zsh \
    \
    atload'
        unfunction uninstall_oh_my_zsh
        unfunction upgrade_oh_my_zsh
    ' \
        OMZL::functions.zsh \
    \
    atload'
        # Set title to the current directory, without username and hostname.
        ZSH_THEME_TERM_TITLE_IDLE="%~"
    ' \
        OMZL::termsupport.zsh \
    \
    atload'
        # Every macOS login shell re-runs path_helper (/etc/zprofile), which reorders PATH and pushes brew behind the system paths.
        # Re-run brew shellenv (always, not just in tmux) to move the Homebrew bin folder back to the front, so commands from brew take precedence (ex. git).
        if command -v brew > /dev/null; then
            eval "$(brew shellenv)"
        fi

        # brew shellenv prepends its bin dirs, so re-prepend polaris/bin afterwards to keep zinit-installed tools ahead of brew (ex. fzf, rg, delta).
        # Net priority: zinit (polaris) > brew > system.
        path=("${ZINIT[POLARIS_DIR]}/bin" "${(@)path:#${ZINIT[POLARIS_DIR]}/bin}")
    ' \
        OMZP::brew

zinit wait lucid for \
    OMZL::clipboard.zsh \
    OMZL::directories.zsh \
    OMZL::git.zsh \
    OMZL::grep.zsh \
    \
    atload'
        bindkey '^r' history-incremental-pattern-search-backward
        bindkey '^s' history-incremental-pattern-search-forward
    ' \
        OMZL::key-bindings.zsh \
    \
    OMZP::cp \
    OMZP::git \
    \
    atload'
        MARKPATH="$XDG_DATA_HOME/marks"

        alias j='jump'     # Jump to a directory
        alias jc='mark'    # Mark the current directory
        alias jd='unmark'  # Unmark the current directory
        alias jl='marks'   # List all marks
    ' \
        OMZP::jump \
    \
    has'eza' \
        OMZP::eza

zinit wait lucid as'completion' blockf for \
    OMZP::terraform/_terraform


