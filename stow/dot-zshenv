# XDG
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# ZSH
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# System Config
export PATH="$HOME/.local/bin:$PATH"
export PAGER="less -FX"

# Homebrew
export HOMEBREW_NO_ANALYTICS=1

# uv
export UV_MANAGED_PYTHON=true
export UV_PYTHON_INSTALL_BIN=false
export UV_NO_MODIFY_PATH=true

# Vite+
export VP_HOME="$XDG_DATA_HOME/vite-plus"
[[ -f "$VP_HOME/env" ]] && . "$VP_HOME/env"

# go (XDG-ify the remaining defaults; GOROOT/GOBIN are managed per-version by mise)
# GOPATH/GOMODCACHE are version-independent and safe to share across all versions.
export GOPATH="$XDG_DATA_HOME/go"
export GOENV="$XDG_CONFIG_HOME/go/env"
export GOCACHE="$XDG_CACHE_HOME/go-build"

# My Dotfiles
export DOTFILES_HOME="${DOTFILES_HOME:-${HOME}/.dotfiles}"
